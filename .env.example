# ============================================================
# CENTRAL PESSOAL ADAPTA — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NÃO deve ser versionado no git.

# ---- Supabase (banco de dados + autenticação) ----
# Obtenha em: app.supabase.com → Configurações → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Google Calendar + Drive ----
# Obtenha em: console.cloud.google.com
# Crie um projeto > habilite "Google Calendar API" e "Google Drive API"
# Credenciais > Criar ID do cliente OAuth 2.0 (tipo: Aplicativo Web)
# Adicione http://localhost:5173 em "Origens JavaScript autorizadas"
# NUNCA coloque o client_secret aqui — use apenas o client_id
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Pasta do Google Drive onde o Claude Cowork deposita arquivos de Leitura Diária
VITE_GOOGLE_DRIVE_FOLDER_ID=

# ---- Microsoft Outlook Calendar ----
# Obtenha em: portal.azure.com > Azure Active Directory > Registros de aplicativo
VITE_MICROSOFT_CLIENT_ID=
