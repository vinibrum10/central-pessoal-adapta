# ============================================================
# CENTRAL PESSOAL ADAPTA — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NÃO deve ser versionado no git.

# ---- Google Calendar ----
# Obtenha em: console.cloud.google.com
# Crie um projeto > habilite "Google Calendar API" > Credenciais >
# Criar ID do cliente OAuth 2.0 (tipo: Aplicativo Web)
# Adicione http://localhost:5173 em "Origens JavaScript autorizadas"
VITE_GOOGLE_CLIENT_ID=

# ---- Microsoft Outlook Calendar ----
# Obtenha em: portal.azure.com > Azure Active Directory > Registros de aplicativo
# Crie um app > tipo: SPA > URI de redirecionamento: http://localhost:5173
# Permissões de API: Microsoft Graph > Calendars.Read
VITE_MICROSOFT_CLIENT_ID=
