# ============================================================
# SISTEMA DE GESTÃO PESSOAL — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA versione o arquivo .env no git.

# ---- Supabase (banco de dados + autenticação) OBRIGATÓRIO ----
# Crie projeto em: app.supabase.com
# Vá em: Settings → API
# Project URL → VITE_SUPABASE_URL
# anon / public key → VITE_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Modo local (apenas desenvolvimento) ----
# Defina como true para rodar sem Supabase em modo dev.
# EM PRODUÇÃO ESTA VARIÁVEL É IGNORADA.
# VITE_ENABLE_LOCAL_MODE=true

# ---- Google Calendar + Drive ----
# console.cloud.google.com → projeto → habilite Calendar API + Drive API
# Credenciais → OAuth 2.0 → Aplicativo Web
# Origens autorizadas: http://localhost:5173 e https://seu-app.vercel.app
# NUNCA coloque client_secret aqui
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_DRIVE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_YOUTUBE_API_KEY=

# IDs da árvore Google Drive do SGP. Use apenas IDs, nunca a URL completa.
VITE_SGP_DRIVE_ROOT_FOLDER_ID=146Xbn1G3icqxjie2gBVbm_kdYoWSN1nO
VITE_GOOGLE_DRIVE_FOLDER_ID=1HIoT04CrKP_UzwbhivUpkEb6w7245Gvl
VITE_SGP_DRIVE_CONFIG_FOLDER_ID=1ftSfXxwhi2Lvs8eVfB9ATH53OAlJRVMh
VITE_SGP_DRIVE_LEITURA_TECNOLOGIA_FOLDER_ID=1shhLeRDHDVVTy-GqFAHh5AK6n61A3TgG
VITE_SGP_DRIVE_LEITURA_IA_FOLDER_ID=1IQ5oRv2wvNqlQihhsCjiP4MIJAntmHHK
VITE_SGP_DRIVE_LEITURA_ENG_DADOS_FOLDER_ID=17RHSNHPsvIlBpGlLHc4a71kav7ddJD3c
VITE_SGP_DRIVE_LEITURA_SST_FOLDER_ID=1cYG_x0MG0CkGxQFcD-g63XJ-IE8IhC1k
VITE_SGP_DRIVE_LEITURA_ARQUIVADOS_FOLDER_ID=1OcEZiP8k33qKDXN3hyh6xAG-dkL4XhlY
