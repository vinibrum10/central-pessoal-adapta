# ID da pasta do Google Drive para materiais de Inglês
VITE_ENGLISH_DRIVE_FOLDER_ID=

# ---- Claude API (server-side only) ----
# Configure apenas na Vercel/ambiente backend. NUNCA use VITE_ para a chave Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Gemini API (server-side only) ----
# Usada pelo endpoint /api/english/generate-quiz.
# Configure apenas na Vercel/Render/ambiente backend. NUNCA use VITE_ para a chave Gemini.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- Microsoft Outlook Calendar ----
# portal.azure.com → Microsoft Entra → Registros de aplicativo
# Tipo: SPA, sem client secret no front-end.
# Redirect URIs: https://central-pessoal-adapta.vercel.app, http://localhost:5173, http://127.0.0.1:5173
# Permissões delegadas Microsoft Graph: User.Read, Calendars.Read
VITE_MICROSOFT_CLIENT_ID=
